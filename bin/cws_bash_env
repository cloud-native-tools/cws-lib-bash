#!/usr/bin/env bash

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

PROFILED=${ROOT}/profile.d
SCRIPTS=${ROOT}/scripts

for i in ${PROFILED}/*.sh ${SCRIPTS}/*.sh; do
  if [ -r "$i" ]; then
    if [ "${-#*i}" != "$-" ]; then
      . "$i"
    else
      . "$i" >/dev/null
    fi
  fi
done
unset i

export CWS_LIB_BASH_HOME=${ROOT}

# Use env_append function to manage PATH (auto-prunes duplicates)
env_append PATH "${CWS_LIB_BASH_HOME}/bin"
